{
  "brand": {
    "name": "JB Digital Consulting",
    "personality": "sophisticated silence — institutional B2B, premium, no noise",
    "audience": "Brazilian B2B professionals, decision-makers 35–55, desktop-primary"
  },
  "colors": {
    "navy": {
      "900": "hsl(212 58% 10%)",
      "800": "hsl(212 45% 13%)",
      "700": "hsl(212 30% 17%)",
      "600": "hsl(212 20% 20%)"
    },
    "gold": {
      "DEFAULT": "hsl(43 53% 54%)",
      "light": "hsl(40 45% 62%)",
      "muted": "hsl(215 16% 62%)"
    },
    "surface": {
      "dark": "hsl(212 58% 10%)",
      "card": "hsl(212 45% 13%)",
      "light": "hsl(40 20% 95%)"
    },
    "text": {
      "primary": "hsl(40 20% 95%)",
      "secondary": "hsl(215 16% 62%)",
      "onLight": "hsl(212 58% 10%)"
    },
    "hex": {
      "navy": "#0C1F3A",
      "gold": "#C9A055",
      "goldLight": "#D4B07A",
      "offWhite": "#F5F0E8",
      "cardDark": "#132845"
    }
  },
  "typography": {
    "fontFamily": {
      "display": "DM Serif Display, Georgia, serif",
      "body": "Inter, system-ui, sans-serif"
    },
    "usage": {
      "h1-h4": "DM Serif Display — gold on dark sections, navy on light sections",
      "body": "Inter — off-white on dark, navy on light",
      "overline": "Inter uppercase, letter-spacing 0.12em, small caps"
    }
  },
  "spacing": {
    "sectionVertical": "6rem",
    "containerMax": "1200px",
    "containerPadding": "2rem"
  },
  "radius": {
    "sm": "4px",
    "md": "6px",
    "lg": "12px"
  },
  "components": {
    "buttonPrimary": {
      "background": "hsl(43 53% 54%)",
      "text": "hsl(212 58% 10%)",
      "radius": "6px",
      "padding": "12px 28px",
      "font": "Inter 500"
    },
    "buttonSecondary": {
      "background": "transparent",
      "border": "1px solid hsl(43 53% 54%)",
      "text": "hsl(43 53% 54%)",
      "radius": "6px"
    },
    "card": {
      "background": "hsl(212 45% 13% / 0.6)",
      "border": "1px solid hsl(43 53% 54% / 0.12)",
      "borderHover": "1px solid hsl(43 53% 54% / 0.25)",
      "backdropFilter": "blur(20px)"
    },
    "sectionDivider": {
      "height": "1px",
      "background": "linear-gradient(90deg, transparent, hsl(43 53% 54% / 0.2), transparent)"
    }
  },
  "patterns": {
    "sectionAlternation": "dark navy (#0C1F3A) ↔ off-white (#F5F0E8)",
    "iconStyle": "line-style only, gold on dark backgrounds",
    "motif": "hexagonal shape from logo — use for badges, section markers",
    "noGradients": true,
    "noDropShadows": "use subtle gold glow (box-shadow with gold/5%) instead"
  }
}
